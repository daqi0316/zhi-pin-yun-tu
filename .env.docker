# Docker 部署环境变量（docker-compose.yml 中已设置默认值）
# 自定义请修改 docker-compose.yml 的 app.environment 段，或创建 .env 文件后通过 env_file 挂载

# ── 必填 ────────────────────────────────────────────────────────
APP_ID=zhypx-dev
APP_SECRET=dev-secret-change-in-production

# ── 数据库（容器内通过 service name "mysql" 访问）───────────────
DATABASE_URL=mysql://root:723319@mysql:3306/zhypx

# ── 服务端口 ────────────────────────────────────────────────────
PORT=3001
APP_URL=http://localhost:3001

# ── 可选 ────────────────────────────────────────────────────────
KIMI_AUTH_URL=http://auth.local
KIMI_OPEN_URL=http://open.local
OWNER_UNION_ID=admin
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
